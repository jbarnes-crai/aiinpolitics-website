---
export interface Props {
  eyebrow?: string;
  title: string;
  lede?: string;
}

const { eyebrow, title, lede } = Astro.props;
---

<header class="page-header">
  <div class="container">
    {eyebrow && <span class="eyebrow">{eyebrow}</span>}
    <h1>{title}</h1>
    {lede && <p class="lede">{lede}</p>}
    <slot />
  </div>
</header>
