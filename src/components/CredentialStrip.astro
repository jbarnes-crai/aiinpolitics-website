---
import {
  AUTHENTIC_URL,
  QUILLER_URL,
  C_AND_E_AI_LEADER_AWARD_URL,
  C_AND_E_AI_PIONEER_AWARD_URL,
} from '~/config/links';

const items: ReadonlyArray<{ label: string; href?: string }> = [
  { label: 'CEO of Authentic', href: AUTHENTIC_URL },
  { label: 'Co-founder of Quiller', href: QUILLER_URL },
  {
    label: 'Campaigns & Elections AI Leader of the Year 2025',
    href: C_AND_E_AI_LEADER_AWARD_URL,
  },
  {
    label: 'Campaigns & Elections AI Pioneer of the Year 2026',
    href: C_AND_E_AI_PIONEER_AWARD_URL,
  },
  {
    label: 'Multiple award winner: Reeds, CampaignTech, AAPC Pollies, Shorty, Webby Awards, and more!',
  },
  {
    label: 'Speaker on AI at various conferences',
  },
];
---

<ul class="credentials" aria-label="Credentials">
  {items.map((item) => (
    <li>
      {item.href ? (
        <a href={item.href} rel="noopener">{item.label}</a>
      ) : (
        item.label
      )}
    </li>
  ))}
</ul>
