---
import Layout from '~/layouts/Layout.astro';
import PageHeader from '~/components/PageHeader.astro';
import CredentialStrip from '~/components/CredentialStrip.astro';
import FrameworkCard from '~/components/FrameworkCard.astro';
import ArticleCard from '~/components/ArticleCard.astro';
import {
  SITE,
  AUTHENTIC_URL,
  QUILLER_URL,
  C_AND_E_AI_LEADER_AWARD_URL,
  C_AND_E_AI_PIONEER_AWARD_URL,
  FEATURED_MEDIA,
  SUBSTACK_URL,
} from '~/config/links';

const title = 'AI in Politics — Practical AI Strategy for Democratic Campaigns';
const description =
  'AI in Politics is written by Jonathan Barnes, CEO of Authentic, co-founder of Quiller, and a Campaigns & Elections AI Leader/Pioneer. Practical AI strategy for Democratic campaigns and progressive organizations.';

const websiteLd = {
  '@context': 'https://schema.org',
  '@type': 'WebSite',
  '@id': `${SITE.url}#website`,
  url: SITE.url,
  name: SITE.name,
  description: SITE.description,
  inLanguage: 'en',
  publisher: { '@id': `${SITE.url}#org` },
};

const orgLd = {
  '@context': 'https://schema.org',
  '@type': 'Organization',
  '@id': `${SITE.url}#org`,
  name: SITE.name,
  url: SITE.url,
  description: SITE.description,
  founder: { '@id': `${SITE.url}/jonathan-barnes#person` },
};

const personLd = {
  '@context': 'https://schema.org',
  '@type': 'Person',
  '@id': `${SITE.url}/jonathan-barnes#person`,
  name: 'Jonathan Barnes',
  url: `${SITE.url}/jonathan-barnes`,
  jobTitle: 'CEO',
  worksFor: { '@type': 'Organization', name: 'Authentic', url: AUTHENTIC_URL },
  founder: { '@type': 'Organization', name: 'Quiller', url: QUILLER_URL },
  award: [
    'Campaigns & Elections CampaignTech AI Leader of the Year',
    'Campaigns & Elections Reed Awards AI Pioneer of the Year',
  ],
  sameAs: [
    C_AND_E_AI_LEADER_AWARD_URL,
    C_AND_E_AI_PIONEER_AWARD_URL,
    FEATURED_MEDIA.url,
    AUTHENTIC_URL,
    QUILLER_URL,
  ],
};
---

<Layout
  title={title}
  description={description}
  path="/"
  jsonLd={[websiteLd, orgLd, personLd]}
>
  <PageHeader
    eyebrow="AI in Politics"
    title="Practical AI strategy for Democratic campaigns."
    lede="AI in Politics is written by Jonathan Barnes, CEO of Authentic, co-founder of Quiller, and a Campaigns & Elections AI Leader of the Year and AI Pioneer of the Year."
  >
    <p class="lede" style="margin-top: 1rem;">
      Jonathan writes about how Democratic campaigns, progressive
      organizations, and political firms can move beyond scattered AI
      experiments toward practical, human-reviewed systems for fundraising,
      communications, operations, and decision-making.
    </p>
    <div class="btn-row">
      <a href="/campaign-ai-operating-system" class="btn btn-primary">
        Read the Framework
      </a>
      <a href="/jonathan-barnes" class="btn btn-secondary">
        About Jonathan
      </a>
    </div>
  </PageHeader>

  <section class="section" aria-labelledby="credentials-heading">
    <div class="container">
      <h2 id="credentials-heading" class="sr-only">Credentials</h2>
      <CredentialStrip />
    </div>
  </section>

  <section class="section" aria-labelledby="featured-framework">
    <div class="container">
      <h2 id="featured-framework">Featured framework</h2>
      <p class="prose">
        The first wave of political AI was tool discovery. The next phase is
        operational — how campaigns organize knowledge, tasks, human review,
        approvals, and decisions around AI.
      </p>
      <div class="card-grid">
        <FrameworkCard
          href="/campaign-ai-operating-system"
          meta="Flagship framework"
          title="The Campaign AI Operating System"
          description="A practical framework for moving Democratic campaigns from scattered AI experiments to human-reviewed workflows. Five layers: trusted knowledge, defined tasks, human review, decision rights, and a staff-facing interface."
        />
      </div>
    </div>
  </section>

  <section class="section" aria-labelledby="latest-writing">
    <div class="container">
      <h2 id="latest-writing">Latest writing</h2>
      <p class="prose">
        Essays on AI operations, campaign infrastructure, and what works
        inside political organizations — not generic AI hype.
      </p>
      <div class="card-grid cols-2">
        <ArticleCard
          href="/writing"
          meta="Essay"
          title="Campaigns Don’t Need More AI Tools. They Need an AI Operating System."
          description="Why the next phase of political AI is operational, not tool-by-tool."
        />
        <ArticleCard
          href="/writing"
          meta="Essay"
          title="Where AI Belongs in Each Campaign Department"
          description="A department-by-department view of what AI should and should not touch on a campaign."
        />
      </div>
      <p style="margin-top: 1.5rem;">
        <a href="/writing">All writing →</a>
        <span aria-hidden="true"> · </span>
        <a href={SUBSTACK_URL} rel="noopener">Subscribe on Substack</a>
      </p>
    </div>
  </section>

  <section class="section" aria-labelledby="about-jonathan">
    <div class="container">
      <h2 id="about-jonathan">About Jonathan</h2>
      <div class="prose">
        <p>
          Jonathan Barnes is CEO of <a href={AUTHENTIC_URL} rel="noopener">Authentic</a>,
          co-founder of <a href={QUILLER_URL} rel="noopener">Quiller</a>, and an
          award-winning Democratic campaign technology leader. His work focuses
          on practical AI systems for Democratic campaigns, progressive
          organizations, and political firms — especially human-reviewed
          workflows, AI-assisted fundraising, campaign operations, and
          staff-facing AI infrastructure.
        </p>
        <p>
          <a href="/jonathan-barnes">Read the full bio →</a>
        </p>
      </div>
    </div>
  </section>

  <section class="section" aria-labelledby="speaking-and-awards">
    <div class="container">
      <h2 id="speaking-and-awards">Speaking and awards</h2>
      <div class="prose">
        <p>
          Jonathan has been recognized by Campaigns &amp; Elections as
          <a href={C_AND_E_AI_LEADER_AWARD_URL} rel="noopener">AI Leader of the Year</a>
          and
          <a href={C_AND_E_AI_PIONEER_AWARD_URL} rel="noopener">AI Pioneer of the Year</a>,
          and has won multiple Campaigns &amp; Elections awards for campaign
          technology and digital work. He speaks regularly at Campaigns &amp;
          Elections conferences on the operational side of AI adoption inside
          political organizations.
        </p>
        <p>
          Featured coverage:
          <a href={FEATURED_MEDIA.url} rel="noopener">
            {FEATURED_MEDIA.title}
          </a>
          — <em>{FEATURED_MEDIA.publication}</em>.
        </p>
        <p>
          <a href="/speaking-awards">Speaking &amp; awards →</a>
        </p>
      </div>
    </div>
  </section>
</Layout>
